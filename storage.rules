// Marie Borders — Cloud Storage security rules
//
// Default-deny. Public read on listing photos + site assets so the public
// site can render images. Writes require an authenticated user (Marie).

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthed() { return request.auth != null; }

    match /listing-photos/{listingId}/{file} {
      allow read: if true;
      // Authed writes only. Images + listing videos share this path; cap size
      // (backstop — the CMS enforces a 10 MB video limit client-side) and
      // restrict to image/video content types.
      allow write: if isAuthed()
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Raw listing-video uploads awaiting server-side compression. The CMS
    // uploads here; the onListingVideoUploaded function transcodes to a
    // <10 MB WebM under listing-photos/ and deletes the raw original. Allow
    // up to 200 MB of any video type (the function enforces the real cap).
    match /listing-video-raw/{scopeId}/{file} {
      // Marie uploads the raw original here; the transcode function (admin SDK)
      // reads it server-side. Size/type checks only apply to writes — putting
      // them on read would deny it (request.resource is null on reads).
      allow read: if isAuthed();
      allow write: if isAuthed()
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }
    match /site/{file} {
      allow read: if true;
      allow write: if isAuthed();
    }
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
